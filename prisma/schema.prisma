// ============================================================================
// FINANCIAL TRANSACTION MODELS
// ============================================================================

enum transaction_type {
  INCOME
  EXPENSE
  DEBT
  LOAN
  CREDIT_CARD
  TRANSFER
}

enum transaction_status {
  PENDING
  COMPLETED
  OVERDUE
}

model financial_transaction {
  id          String           @id @default(cuid())
  businessId  String?
  userId      String?
  type        transaction_type
  title       String
  amount      Float
  category    String
  description String?          @db.Text
  date        DateTime         @default(now())

  // Özel alanlar
  dueDate     DateTime?
  totalAmount Float?
  creditLimit Float?

  status transaction_status @default(COMPLETED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business business? @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "FinancialTransaction_businessId_fkey")
  user     user?     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "FinancialTransaction_userId_fkey")

  @@index([businessId], map: "FinancialTransaction_businessId_idx")
  @@index([userId], map: "FinancialTransaction_userId_idx")
  @@index([date], map: "FinancialTransaction_date_idx")
  @@index([type, date], map: "FinancialTransaction_type_date_idx")
  @@map("financial_transaction")
}

// ============================================================================
// LEGACY CASH ACCOUNT MODELS (Keeping for backward compatibility)
// ============================================================================

model cash_account {
  id         String       @id @default(cuid())
  businessId String
  name       String
  type       account_type @default(CASH)
  balance    Float        @default(0)
  currency   String       @default("TRY")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  business        business           @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CashAccount_businessId_fkey")
  transactions    cash_transaction[] @relation("accountTransactions")
  to_transactions cash_transaction[] @relation("toAccountTransactions")

  @@index([businessId], map: "CashAccount_businessId_idx")
  @@map("cash_account")
}

model cash_transaction {
  id          String           @id @default(cuid())
  businessId  String
  accountId   String
  toAccountId String?
  type        transaction_type
  amount      Float
  category    String
  description String?          @db.Text
  date        DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  business  business      @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CashTransaction_businessId_fkey")
  account   cash_account  @relation("accountTransactions", fields: [accountId], references: [id], onDelete: Cascade, map: "CashTransaction_accountId_fkey")
  toAccount cash_account? @relation("toAccountTransactions", fields: [toAccountId], references: [id], onDelete: Cascade, map: "CashTransaction_toAccountId_fkey")

  @@index([businessId], map: "CashTransaction_businessId_idx")
  @@index([accountId], map: "CashTransaction_accountId_idx")
  @@index([date], map: "CashTransaction_date_idx")
  @@map("cash_transaction")
}

// ============================================================================
// REFERRAL MODELS
// ============================================================================

model referral {
  id           String   @id @default(cuid())
  referrerId   String
  invitedBizId String?
  invitedEmail String?
  referralCode String
  createdAt    DateTime @default(now())

  business business @relation(fields: [referrerId], references: [id], onDelete: Cascade, map: "Referral_referrerId_fkey")

  @@unique([referrerId, invitedBizId], map: "Referral_referrerId_invitedBizId_key")
  @@index([referrerId], map: "Referral_referrerId_idx")
  @@map("referral")
}

// ============================================================================
// SYSTEM & LOGGING MODELS
// ============================================================================

model errorlog {
  id        String   @id @default(cuid())
  service   String
  level     String   @default("ERROR")
  message   String   @db.Text
  stack     String?  @db.Text
  metadata  String?  @db.LongText
  createdAt DateTime @default(now())

  @@index([service, createdAt], map: "ErrorLog_service_createdAt_idx")
  @@map("errorlog")
}

model eventthrottle {
  id        String   @id @default(cuid())
  key       String   @unique(map: "EventThrottle_key_key")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt], map: "EventThrottle_expiresAt_idx")
  @@map("eventthrottle")
}

model systemstatus {
  id            String   @id @default(cuid())
  key           String   @unique(map: "SystemStatus_key_key")
  value         String?
  lastHeartbeat DateTime @default(now())
  metadata      String?  @db.LongText

  @@index([key], map: "SystemStatus_key_idx")
  @@map("systemstatus")
}

model platformsetting {
  id            String   @id @default(cuid())
  general       Json
  security      Json
  notifications Json
  api           Json
  design        Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("platform_setting")
}

model neighborhood_post {
  id                  String                             @id @default(cuid())
  slug                String                             @unique
  tab                 neighborhood_tab
  type                neighborhood_post_type
  marketplaceCategory neighborhood_marketplace_category?
  status              neighborhood_post_status           @default(PUBLISHED)

  title       String
  content     String? @db.Text
  description String? @db.Text

  price    Float?
  currency String? @default("TL")
  location String?
  city     String?
  district String?

  eventStartAt  DateTime?
  eventEndAt    DateTime?
  eventLocation String?

  isPinned     Boolean @default(false)
  isFeatured   Boolean @default(false)
  viewCount    Int     @default(0)
  likeCount    Int     @default(0)
  commentCount Int     @default(0)
  shareCount   Int     @default(0)

  authorUserId     String?
  authorBusinessId String?

  contactPhone    String?
  contactWhatsapp String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorUser     user?     @relation(fields: [authorUserId], references: [id], onDelete: SetNull, map: "NeighborhoodPost_authorUserId_fkey")
  authorBusiness business? @relation(fields: [authorBusinessId], references: [id], onDelete: SetNull, map: "NeighborhoodPost_authorBusinessId_fkey")

  images     neighborhood_post_image[]
  attributes neighborhood_post_attribute[]
  comments   neighborhood_post_comment[]
  likes      neighborhood_post_like[]

  @@index([tab, status, createdAt], map: "NeighborhoodPost_tab_status_createdAt_idx")
  @@index([marketplaceCategory, status], map: "NeighborhoodPost_marketplaceCategory_status_idx")
  @@index([authorUserId], map: "NeighborhoodPost_authorUserId_idx")
  @@index([authorBusinessId], map: "NeighborhoodPost_authorBusinessId_idx")
  @@map("neighborhood_post")
}

model neighborhood_post_image {
  id        String   @id @default(cuid())
  postId    String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  post neighborhood_post @relation(fields: [postId], references: [id], onDelete: Cascade, map: "NeighborhoodPostImage_postId_fkey")

  @@index([postId, sortOrder], map: "NeighborhoodPostImage_postId_sortOrder_idx")
  @@map("neighborhood_post_image")
}

model neighborhood_post_attribute {
  id        String @id @default(cuid())
  postId    String
  label     String
  value     String
  sortOrder Int    @default(0)

  post neighborhood_post @relation(fields: [postId], references: [id], onDelete: Cascade, map: "NeighborhoodPostAttribute_postId_fkey")

  @@index([postId, sortOrder], map: "NeighborhoodPostAttribute_postId_sortOrder_idx")
  @@map("neighborhood_post_attribute")
}

model neighborhood_post_comment {
  id         String   @id @default(cuid())
  postId     String
  userId     String?
  businessId String?
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post     neighborhood_post @relation(fields: [postId], references: [id], onDelete: Cascade, map: "NeighborhoodPostComment_postId_fkey")
  user     user?             @relation(fields: [userId], references: [id], onDelete: SetNull, map: "NeighborhoodPostComment_userId_fkey")
  business business?         @relation(fields: [businessId], references: [id], onDelete: SetNull, map: "NeighborhoodPostComment_businessId_fkey")

  @@index([postId, createdAt], map: "NeighborhoodPostComment_postId_createdAt_idx")
  @@index([userId], map: "NeighborhoodPostComment_userId_idx")
  @@index([businessId], map: "NeighborhoodPostComment_businessId_idx")
  @@map("neighborhood_post_comment")
}

model neighborhood_post_like {
  id         String   @id @default(cuid())
  postId     String
  userId     String?
  businessId String?
  createdAt  DateTime @default(now())

  post     neighborhood_post @relation(fields: [postId], references: [id], onDelete: Cascade, map: "NeighborhoodPostLike_postId_fkey")
  user     user?             @relation(fields: [userId], references: [id], onDelete: SetNull, map: "NeighborhoodPostLike_userId_fkey")
  business business?         @relation(fields: [businessId], references: [id], onDelete: SetNull, map: "NeighborhoodPostLike_businessId_fkey")

  @@unique([postId, userId], map: "NeighborhoodPostLike_postId_userId_key")
  @@unique([postId, businessId], map: "NeighborhoodPostLike_postId_businessId_key")
  @@index([postId], map: "NeighborhoodPostLike_postId_idx")
  @@map("neighborhood_post_like")
}

