// ============================================================================
// BUSINESS LOANS (Krediler)
// ============================================================================

enum loan_payment_schedule {
  MONTHLY
  WEEKLY
  BIWEEKLY
  QUARTERLY
  YEARLY
}

model business_loan {
  id                    String                @id @default(cuid())
  businessId            String
  name                  String
  remainingDebt         Float
  remainingInstallments Int
  nextInstallmentDate   DateTime
  paymentSchedule       loan_payment_schedule @default(MONTHLY)
