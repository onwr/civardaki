generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH MODELS
// ============================================================================

model user {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique(map: "User_email_key")
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          user_role   @default(USER)
  status        user_status @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  account               account[]
  emaillog              emaillog[]
  ownedbusiness         ownedbusiness[]
  review                review[]
  session               session[]
  financial_transaction financial_transaction[]

  neighborhoodPosts    neighborhood_post[]
  neighborhoodComments neighborhood_post_comment[]
  neighborhoodLikes    neighborhood_post_like[]

  order                  order[]
  reservation            reservation[]
  user_address           user_address[]
  user_favorite_business user_favorite_business[]
  user_profile_settings  user_profile_settings?
  businessadminnote      businessadminnote[]
  businessNotes          business_note[]        @relation("BusinessNoteAuthor")
  requestedLeaveRequests employee_leave_request[] @relation("EmployeeLeaveRequestedBy")
  approvedLeaveRequests  employee_leave_request[] @relation("EmployeeLeaveApprovedBy")
  useradminnote          useradminnote[]         @relation("UserAdminNoteSubject")
  authoredUseradminnote  useradminnote[]         @relation("UserAdminNoteAuthor")
  createdAds             ad[]                   @relation("AdCreatedBy")
  createdBroadcasts      broadcast[]            @relation("BroadcastCreatedBy")
  supportTickets           support_ticket[]           @relation("SupportTicketUser")
  supportTicketMessages   support_ticket_message[]   @relation("SupportTicketMessageUser")

  @@map("user")
}

model user_address {
  id        String   @id @default(cuid())
  userId    String
  title     String
  line1     String   @db.Text
  line2     String?  @db.Text
  city      String
  district  String?
  mahalle   String?
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserAddress_userId_fkey")

  @@index([userId], map: "UserAddress_userId_idx")
  @@map("user_address")
}

model user_favorite_business {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserFavoriteBusiness_userId_fkey")
  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "UserFavoriteBusiness_businessId_fkey")

  @@unique([userId, businessId], map: "UserFavoriteBusiness_userId_businessId_key")
  @@index([userId], map: "UserFavoriteBusiness_userId_idx")
  @@index([businessId], map: "UserFavoriteBusiness_businessId_idx")
  @@map("user_favorite_business")
}

model user_profile_settings {
  id                     String   @id @default(cuid())
  userId                 String   @unique(map: "UserProfileSettings_userId_key")
  language               String   @default("tr-TR")
  campaignNotifications  Boolean  @default(true)
  smsOrderNotifications  Boolean  @default(true)
  newsletterNotifications Boolean @default(true)
  profileVisibility      String   @default("PRIVATE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserProfileSettings_userId_fkey")

  @@index([userId], map: "UserProfileSettings_userId_idx")
  @@map("user_profile_settings")
}

model account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user user @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@unique([provider, providerAccountId], map: "Account_provider_providerAccountId_key")
  @@index([userId], map: "Account_userId_fkey")
  @@map("account")
}

model session {
  id           String   @id @default(cuid())
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime

  user user @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Session_userId_fkey")

  @@index([userId], map: "Session_userId_fkey")
  @@map("session")
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token], map: "VerificationToken_identifier_token_key")
  @@map("verificationtoken")
}

// ============================================================================
// BUSINESS MODELS
// ============================================================================

model business {
  id          String        @id @default(cuid())
  slug        String        @unique(map: "Business_slug_key")
  name        String
  description String?       @db.Text
  type        business_type @default(INDIVIDUAL)
  category    String?
  phone       String?
  email       String?
  website     String?
  address     String?       @db.Text
  city        String?
  district    String?
  latitude    Float?
  longitude   Float?
  isVerified  Boolean       @default(false)
  isActive    Boolean       @default(true)
  isOpen      Boolean       @default(true)
  reservationEnabled Boolean @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  primaryCategoryId String?

  services           String? @db.LongText
  workingHours       String? @db.LongText
  rating             Float   @default(0)
  ratingSum          Int     @default(0)
  reviewCount        Int     @default(0)
  avgResponseMinutes Float   @default(0)
  responseCount      Int     @default(0)
  referralCode       String? @unique(map: "Business_referralCode_key")

  officialName       String?
  taxId              String?
  taxOffice          String?
  representativeName String?
  vision             String? @db.Text

  cargoSettings        String? @db.LongText
  securitySettings     String? @db.LongText
  notificationSettings String? @db.LongText

  primaryCategory       category?                   @relation("BusinessPrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: SetNull)
  businesscategory      businesscategory[]
  businessevent         businessevent[]
  businesssubscription  businesssubscription?
  subscription_payment  subscription_payment[]
  invoice               invoice[]
  emaillog              emaillog[]
  lead                  lead[]
  leadreminder          leadreminder[]
  media                 media[]
  notification          notification[]
  ownedbusiness         ownedbusiness[]
  product               product[]
  ecommerceProductMatch ecommerce_product_match[]
  productcategory       productcategory[]
  catalog               catalog[]
  pricelist             pricelist[]
  production_run        production_run[]
  warehouse             warehouse[]
  referral              referral[]
  review                review[]
  order                 order[]
  quotes                quote[]
  reservations          reservation[]
  reservationSettings   business_reservation_settings?
  asset                 asset[]
  employee              employee[]
  employeeDepartments   employee_department[]
  employeeLeaveRequests employee_leave_request[]
  calendar_event        calendar_event[]
  cash_account          cash_account[]
  cash_transaction      cash_transaction[]
  financial_transaction financial_transaction[]
  neighborhoodPosts     neighborhood_post[]
  neighborhoodComments  neighborhood_post_comment[]
  neighborhoodLikes     neighborhood_post_like[]
  user_favorite_business user_favorite_business[]
  businessadminnote     businessadminnote[]
  businessNotes         business_note[]
  supportTickets          support_ticket[]           @relation("SupportTicketBusiness")
  supportTicketMessages   support_ticket_message[]   @relation("SupportTicketMessageBusiness")
  planningProjects        planning_project[]
  planningTasks           planning_task[]

  @@index([city, district], map: "Business_city_district_idx")
  @@index([slug], map: "Business_slug_idx")
  @@index([primaryCategoryId], map: "Business_primaryCategoryId_idx")
  @@map("business")
}

model ownedbusiness {
  userId     String
  businessId String
  isPrimary  Boolean @default(false)

  user     user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "OwnedBusiness_userId_fkey")
  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "OwnedBusiness_businessId_fkey")

  @@id([userId, businessId])
  @@index([businessId], map: "OwnedBusiness_businessId_idx")
  @@map("ownedbusiness")
}

model businesscategory {
  businessId String
  categoryId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessCategory_businessId_fkey")
  category category @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "BusinessCategory_categoryId_fkey")

  @@id([businessId, categoryId])
  @@index([categoryId], map: "BusinessCategory_categoryId_fkey")
  @@index([businessId, isPrimary], map: "BusinessCategory_businessId_isPrimary_idx")
  @@index([categoryId, isPrimary], map: "BusinessCategory_categoryId_isPrimary_idx")
  @@map("businesscategory")
}

model businessevent {
  id         String             @id @default(cuid())
  businessId String
  type       businessevent_type
  productId  String?
  createdAt  DateTime           @default(now())
  ipHash     String?            @db.VarChar(64)
  userAgent  String?            @db.VarChar(255)

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessEvent_businessId_fkey")

  @@index([businessId, type, createdAt], map: "BusinessEvent_businessId_type_createdAt_idx")
  @@index([ipHash, createdAt], map: "BusinessEvent_ipHash_createdAt_idx")
  @@map("businessevent")
}

model businesssubscription {
  id         String                      @id @default(cuid())
  businessId String                      @unique(map: "BusinessSubscription_businessId_key")
  status     businesssubscription_status
  plan       businesssubscription_plan   @default(BASIC)
  startedAt  DateTime
  expiresAt  DateTime
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  business  business             @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessSubscription_businessId_fkey")
  subscription_payment subscription_payment[]

  @@index([businessId], map: "BusinessSubscription_businessId_idx")
  @@map("businesssubscription")
}

model subscription_payment {
  id                 String                     @id @default(cuid())
  businessId         String
  subscriptionId     String?
  amount             Float
  currency           String                     @default("TRY")
  status             subscription_payment_status @default(PENDING)
  provider           String?
  providerReference  String?
  paidAt             DateTime?
  metadata           Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  business     business              @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "SubscriptionPayment_businessId_fkey")
  subscription businesssubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull, map: "SubscriptionPayment_subscriptionId_fkey")
  invoice      invoice[]

  @@index([businessId], map: "SubscriptionPayment_businessId_idx")
  @@index([subscriptionId], map: "SubscriptionPayment_subscriptionId_idx")
  @@index([status], map: "SubscriptionPayment_status_idx")
  @@index([providerReference], map: "SubscriptionPayment_providerReference_idx")
  @@index([createdAt], map: "SubscriptionPayment_createdAt_idx")
  @@map("subscription_payment")
}

model invoice {
  id                    String         @id @default(cuid())
  businessId            String
  subscriptionPaymentId String?
  invoiceNumber         String         @unique(map: "Invoice_invoiceNumber_key")
  type                  invoice_type   @default(MANUAL)
  status                invoice_status @default(DRAFT)
  amount                Float
  currency              String         @default("TRY")
  issueDate             DateTime
  dueDate               DateTime
  description           String?        @db.Text
  pdfUrl                String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  business             business              @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Invoice_businessId_fkey")
  subscriptionPayment  subscription_payment? @relation(fields: [subscriptionPaymentId], references: [id], onDelete: SetNull, map: "Invoice_subscriptionPaymentId_fkey")

  @@index([businessId], map: "Invoice_businessId_idx")
  @@index([subscriptionPaymentId], map: "Invoice_subscriptionPaymentId_idx")
  @@index([status], map: "Invoice_status_idx")
  @@index([issueDate], map: "Invoice_issueDate_idx")
  @@map("invoice")
}

model businessadminnote {
  id         String   @id @default(cuid())
  businessId String
  authorId   String?
  note       String   @db.Text
  createdAt  DateTime @default(now())

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessAdminNote_businessId_fkey")
  author   user?    @relation(fields: [authorId], references: [id], onDelete: SetNull, map: "BusinessAdminNote_authorId_fkey")

  @@index([businessId], map: "BusinessAdminNote_businessId_idx")
  @@map("business_admin_note")
}

model useradminnote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String?
  note      String   @db.Text
  createdAt DateTime @default(now())

  user   user  @relation("UserAdminNoteSubject", fields: [userId], references: [id], onDelete: Cascade, map: "UserAdminNote_userId_fkey")
  author user? @relation("UserAdminNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull, map: "UserAdminNote_authorId_fkey")

  @@index([userId], map: "UserAdminNote_userId_idx")
  @@map("user_admin_note")
}

model business_note {
  id           String    @id @default(cuid())
  businessId   String
  authorUserId String?
  title        String
  content      String    @db.Text
  category     String    @default("Genel")
  color        String    @default("blue")
  tags         Json?
  isPinned     Boolean   @default(false)
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessNote_businessId_fkey")
  author   user?    @relation("BusinessNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull, map: "BusinessNote_authorUserId_fkey")

  @@index([businessId, createdAt], map: "BusinessNote_businessId_createdAt_idx")
  @@index([businessId, category], map: "BusinessNote_businessId_category_idx")
  @@index([businessId, isPinned], map: "BusinessNote_businessId_isPinned_idx")
  @@index([businessId, archivedAt], map: "BusinessNote_businessId_archivedAt_idx")
  @@map("business_note")
}

// ============================================================================
// ADS (Reklamlar)
// ============================================================================

model ad {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  imageUrl    String?
  linkUrl     String?
  placement   ad_placement
  status      ad_status     @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  sortOrder   Int           @default(0)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy user? @relation("AdCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, map: "Ad_createdById_fkey")

  @@index([placement, status], map: "Ad_placement_status_idx")
  @@index([status, startAt, endAt], map: "Ad_status_dates_idx")
  @@map("ad")
}

// ============================================================================
// BROADCASTS (Duyurular)
// ============================================================================

model broadcast {
  id          String              @id @default(cuid())
  title       String
  body        String?             @db.Text
  imageUrl    String?
  linkUrl     String?
  linkLabel   String?
  layout      broadcast_layout
  audience    broadcast_audience
  status      broadcast_status    @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  sortOrder   Int                 @default(0)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  createdBy user? @relation("BroadcastCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, map: "Broadcast_createdById_fkey")

  @@index([layout, audience, status], map: "Broadcast_layout_audience_status_idx")
  @@index([status, startAt, endAt], map: "Broadcast_status_dates_idx")
  @@map("broadcast")
}

// ============================================================================
// SUPPORT TICKETS (Destek Talepleri)
// ============================================================================

model support_ticket {
  id          String               @id @default(cuid())
  subject     String
  body        String                @db.Text
  creatorType ticket_creator_type
  userId      String?
  businessId  String?
  status      ticket_status         @default(OPEN)
  priority    ticket_priority       @default(MEDIUM)
  category    ticket_category       @default(GENERAL)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user     user?                    @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: SetNull, map: "SupportTicket_userId_fkey")
  business business?                @relation("SupportTicketBusiness", fields: [businessId], references: [id], onDelete: SetNull, map: "SupportTicket_businessId_fkey")
  messages support_ticket_message[]

  @@index([status, createdAt], map: "SupportTicket_status_createdAt_idx")
  @@index([userId], map: "SupportTicket_userId_idx")
  @@index([businessId], map: "SupportTicket_businessId_idx")
  @@map("support_ticket")
}

model support_ticket_message {
  id               String                     @id @default(cuid())
  supportTicketId  String
  body             String                     @db.Text
  authorType       ticket_message_author_type
  authorUserId     String?
  authorBusinessId String?
  createdAt        DateTime                   @default(now())

  supportTicket support_ticket @relation(fields: [supportTicketId], references: [id], onDelete: Cascade, map: "SupportTicketMessage_supportTicketId_fkey")
  user          user?          @relation("SupportTicketMessageUser", fields: [authorUserId], references: [id], onDelete: SetNull, map: "SupportTicketMessage_authorUserId_fkey")
  business      business?     @relation("SupportTicketMessageBusiness", fields: [authorBusinessId], references: [id], onDelete: SetNull, map: "SupportTicketMessage_authorBusinessId_fkey")

  @@index([supportTicketId], map: "SupportTicketMessage_supportTicketId_idx")
  @@map("support_ticket_message")
}

// ============================================================================
// CATEGORY MODELS
// ============================================================================

model category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique(map: "Category_slug_key")
  description String?  @db.Text
  icon        String?
  color       String?
  imageUrl    String?
  parentId    String?
  level       Int      @default(0)
  path        String?  @db.VarChar(500)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  keywords    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent            category?          @relation("category_children", fields: [parentId], references: [id], onDelete: Cascade, map: "Category_parentId_fkey")
  children          category[]         @relation("category_children")
  businesscategory  businesscategory[]
  primaryBusinesses business[]         @relation("BusinessPrimaryCategory")

  @@unique([parentId, name], map: "Category_parentId_name_key")
  @@index([parentId, sortOrder], map: "Category_parentId_sortOrder_idx")
  @@index([level, isActive], map: "Category_level_isActive_idx")
  @@index([isActive, isFeatured], map: "Category_isActive_isFeatured_idx")
  @@map("category")
}

// ============================================================================
// PRODUCT & INVENTORY MODELS
// ============================================================================

model product {
  id            String   @id @default(cuid())
  businessId    String
  categoryId    String?
  name          String
  slug          String
  description   String?  @db.Text
  price         Float?
  discountPrice Float?
  imageUrl      String?
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  stock         Int?     // Stok (varyasyon yoksa ürün bazlı)
  maxOrderQty   Int?     // Maksimum sipariş adedi (null = sınırsız)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business        business         @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Product_businessId_fkey")
  productcategory productcategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "Product_categoryId_fkey")
  productvariant  productvariant[]
  catalogitem     catalogitem[]
  pricelistitem   pricelistitem[]
  production_run  production_run[]
  lead            lead[]
  ecommerceMatches ecommerce_product_match[]

  @@unique([businessId, slug], map: "Product_businessId_slug_key")
  @@index([businessId], map: "Product_businessId_idx")
  @@index([categoryId], map: "Product_categoryId_fkey")
  @@map("product")
}

model ecommerce_product_match {
  id                  String                @id @default(cuid())
  businessId          String
  productId           String
  platform            String
  platformProductId   String?
  platformProductName String?
  matchStatus         ecommerce_match_status @default(NOT_LISTED)
  lastSyncedAt        DateTime?
  notes               String?               @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "EcommerceProductMatch_businessId_fkey")
  product  product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "EcommerceProductMatch_productId_fkey")

  @@unique([businessId, productId, platform], map: "EcommerceProductMatch_businessId_productId_platform_key")
  @@index([businessId, platform], map: "EcommerceProductMatch_businessId_platform_idx")
  @@index([businessId, matchStatus], map: "EcommerceProductMatch_businessId_matchStatus_idx")
  @@index([productId], map: "EcommerceProductMatch_productId_idx")
  @@map("ecommerce_product_match")
}

model productvariant {
  id            String   @id @default(cuid())
  productId     String
  name          String   // Örn: Büyük Boy, Kırmızı
  sku           String?
  price         Float?   // Varyasyon fiyatı (boşsa ürün fiyatı)
  discountPrice Float?
  stock         Int      @default(0)
  maxOrderQty   Int?     // Maksimum sipariş adedi (null = sınırsız)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product product @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ProductVariant_productId_fkey")

  @@index([productId], map: "ProductVariant_productId_idx")
  @@map("productvariant")
}

model productcategory {
  id         String @id @default(cuid())
  businessId String
  name       String
  order      Int    @default(0)

  business business  @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "ProductCategory_businessId_fkey")
  product  product[]

  @@unique([businessId, name], map: "ProductCategory_businessId_name_key")
  @@map("productcategory")
}

model catalog {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?  @db.Text
  isPublished Boolean @default(false)
  pdfUrl      String?
  shareUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business business      @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Catalog_businessId_fkey")
  items    catalogitem[]

  @@index([businessId], map: "Catalog_businessId_idx")
  @@map("catalog")
}

model catalogitem {
  id        String  @id @default(cuid())
  catalogId String
  productId String
  order     Int     @default(0)

  catalog catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade, map: "CatalogItem_catalogId_fkey")
  product product @relation(fields: [productId], references: [id], onDelete: Cascade, map: "CatalogItem_productId_fkey")

  @@unique([catalogId, productId], map: "CatalogItem_catalogId_productId_key")
  @@index([catalogId], map: "CatalogItem_catalogId_idx")
  @@index([productId], map: "CatalogItem_productId_idx")
  @@map("catalogitem")
}

model pricelist {
  id           String    @id @default(cuid())
  businessId   String
  name         String
  description  String?   @db.Text
  customerGroup String   @default("ALL") // ALL, VIP, BULK, NEW, CORPORATE
  discountRate Float    @default(0)
  validFrom    DateTime
  validUntil   DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business business        @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Pricelist_businessId_fkey")
  items    pricelistitem[]

  @@index([businessId], map: "Pricelist_businessId_idx")
  @@map("pricelist")
}

model pricelistitem {
  id         String  @id @default(cuid())
  pricelistId String
  productId  String
  order      Int     @default(0)

  pricelist pricelist @relation(fields: [pricelistId], references: [id], onDelete: Cascade, map: "PricelistItem_pricelistId_fkey")
  product   product   @relation(fields: [productId], references: [id], onDelete: Cascade, map: "PricelistItem_productId_fkey")

  @@unique([pricelistId, productId], map: "PricelistItem_pricelistId_productId_key")
