// ============================================================================
// FINANCIAL TRANSACTION MODELS
// ============================================================================

enum transaction_type {
  INCOME
  EXPENSE
  DEBT
  LOAN
  CREDIT_CARD
  TRANSFER
}

enum transaction_status {
  PENDING
  COMPLETED
  OVERDUE
}

model financial_transaction {
  id          String           @id @default(cuid())
  businessId  String?
  userId      String?
  type        transaction_type
  title       String
  amount      Float
  category    String
  description String?          @db.Text
  date        DateTime         @default(now())

  // Özel alanlar
  dueDate     DateTime?
  totalAmount Float?
  creditLimit Float?

  status transaction_status @default(COMPLETED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business business? @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "FinancialTransaction_businessId_fkey")
  user     user?     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "FinancialTransaction_userId_fkey")

  @@index([businessId], map: "FinancialTransaction_businessId_idx")
  @@index([userId], map: "FinancialTransaction_userId_idx")
  @@index([date], map: "FinancialTransaction_date_idx")
  @@index([type, date], map: "FinancialTransaction_type_date_idx")
  @@map("financial_transaction")
}

// ============================================================================
// EXPENSE CATEGORIES (Masraf kalemleri)
// ============================================================================

enum expense_payment_status {
  PENDING
  PAID
}

model expense_category {
  id         String   @id @default(cuid())
  businessId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business business       @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "ExpenseCategory_businessId_fkey")
  items    expense_item[]

  @@index([businessId], map: "ExpenseCategory_businessId_idx")
  @@map("expense_category")
}

model expense_item {
  id         String   @id @default(cuid())
  businessId String
  categoryId String
  name       String
  tagColor   String?  @db.VarChar(32)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   business            @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "ExpenseItem_businessId_fkey")
  category   expense_category    @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "ExpenseItem_categoryId_fkey")
  expenses   cash_transaction[]

  @@index([businessId], map: "ExpenseItem_businessId_idx")
  @@index([categoryId], map: "ExpenseItem_categoryId_idx")
