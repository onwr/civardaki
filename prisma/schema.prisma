  @@index([businessId], map: "BusinessLoan_businessId_idx")
  @@index([cashAccountId], map: "BusinessLoan_cashAccountId_idx")
  @@index([nextInstallmentDate], map: "BusinessLoan_nextInstallmentDate_idx")
  @@map("business_loan")
}

// ============================================================================
// ÇEKLER (çek portföyü)
// ============================================================================

enum check_direction {
  RECEIVED
  ISSUED
}

enum cash_check_status {
  IN_PORTFOLIO
  GIVEN_TO_SUPPLIER
  GIVEN_TO_BANK
  PAID
  BOUNCED
  CANCELLED
}

model cash_check {
  id          String            @id @default(cuid())
  businessId  String
  direction   check_direction   @default(RECEIVED)
  status      cash_check_status @default(IN_PORTFOLIO)
  checkNumber String?
  amount      Float             @default(0)
  issueDate   DateTime?
  dueDate     DateTime?
  bankName    String?
  drawerName  String?
  payeeName   String?
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CashCheck_businessId_fkey")

  @@index([businessId], map: "CashCheck_businessId_idx")
  @@index([businessId, status], map: "CashCheck_businessId_status_idx")
  @@index([dueDate], map: "CashCheck_dueDate_idx")
  @@map("cash_check")
}

enum cash_promissory_note_status {
  IN_PORTFOLIO
  OVERDUE
  GIVEN_TO_SUPPLIER
  GIVEN_TO_BANK
  PAID
  PARTIAL_PAID
  CANCELLED
}

model cash_promissory_note {
  id          String                     @id @default(cuid())
  businessId  String
  direction   check_direction            @default(RECEIVED)
  status      cash_promissory_note_status @default(IN_PORTFOLIO)
  noteNumber  String?
  amount      Float                      @default(0)
  paidAmount  Float                      @default(0)
  issueDate   DateTime?
  dueDate     DateTime?
  drawerName  String?
  payeeName   String?
  notes       String?                    @db.Text
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CashPromissoryNote_businessId_fkey")

  @@index([businessId], map: "CashPromissoryNote_businessId_idx")
  @@index([businessId, status], map: "CashPromissoryNote_businessId_status_idx")
  @@index([dueDate], map: "CashPromissoryNote_dueDate_idx")
  @@map("cash_promissory_note")
}

// ============================================================================
// LEGACY CASH ACCOUNT MODELS (Keeping for backward compatibility)
// ============================================================================

model cash_account {
  id         String       @id @default(cuid())
  businessId String
  name       String
  type       account_type @default(CASH)
  balance    Float        @default(0)
  currency   String       @default("TRY")
  accountNo  String?
  labelColor String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  business        business           @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CashAccount_businessId_fkey")
  transactions    cash_transaction[] @relation("accountTransactions")
  to_transactions cash_transaction[] @relation("toAccountTransactions")
  documents       cash_account_document[]
  business_sales     business_sale[]
  business_purchases business_purchase[]
  business_loans     business_loan[]

  @@index([businessId], map: "CashAccount_businessId_idx")
  @@map("cash_account")
}

model cash_account_document {
  id        String   @id @default(cuid())
  businessId String
  accountId String
  title     String
  url       String
  fileId    String?
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business business    @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CashAccountDocument_businessId_fkey")
  account  cash_account @relation(fields: [accountId], references: [id], onDelete: Cascade, map: "CashAccountDocument_accountId_fkey")

  @@index([businessId], map: "CashAccountDocument_businessId_idx")
  @@index([accountId], map: "CashAccountDocument_accountId_idx")
  @@index([createdAt], map: "CashAccountDocument_createdAt_idx")
  @@map("cash_account_document")
}

/// Nakit / masraf modülü proje ağacı (alt proje destekli)
model cash_project {
  id          String                  @id @default(cuid())
  businessId  String
  parentId    String?
  name        String
  description String?                 @db.Text
  notes       String?                 @db.Text
  status      planning_project_status @default(ACTIVE)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  business     business             @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CashProject_businessId_fkey")
  parent       cash_project?        @relation("CashProjectHierarchy", fields: [parentId], references: [id], onDelete: Cascade, map: "CashProject_parentId_fkey")
  children     cash_project[]       @relation("CashProjectHierarchy")
  transactions cash_transaction[]
  purchases    business_purchase[]
  sales        business_sale[]

  @@index([businessId], map: "CashProject_businessId_idx")
  @@index([businessId, status], map: "CashProject_businessId_status_idx")
  @@index([parentId], map: "CashProject_parentId_idx")
  @@map("cash_project")
}

model cash_transaction {
  id                    String                   @id @default(cuid())
  businessId            String
  accountId             String
  toAccountId           String?
  type                  transaction_type
  amount                Float
  category              String
  description           String?                  @db.Text
  date                  DateTime                 @default(now())
  expensePaymentStatus  expense_payment_status?
  dueDate               DateTime?
  paymentDate           DateTime?
  receiptNo             String?
  vatRate               Float?
  projectName           String?
  notes                 String?                  @db.Text
  recurring             Boolean                  @default(false)
  expenseItemId         String?
  projectId             String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  business    business       @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CashTransaction_businessId_fkey")
  account     cash_account   @relation("accountTransactions", fields: [accountId], references: [id], onDelete: Cascade, map: "CashTransaction_accountId_fkey")
  toAccount   cash_account?  @relation("toAccountTransactions", fields: [toAccountId], references: [id], onDelete: Cascade, map: "CashTransaction_toAccountId_fkey")
  expenseItem expense_item?  @relation(fields: [expenseItemId], references: [id], onDelete: SetNull, map: "CashTransaction_expenseItemId_fkey")
  project     cash_project?  @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "CashTransaction_projectId_fkey")

  @@index([businessId], map: "CashTransaction_businessId_idx")
  @@index([accountId], map: "CashTransaction_accountId_idx")
  @@index([date], map: "CashTransaction_date_idx")
  @@index([expensePaymentStatus], map: "CashTransaction_expensePaymentStatus_idx")
  @@index([expenseItemId], map: "CashTransaction_expenseItemId_idx")
  @@index([projectId], map: "CashTransaction_projectId_idx")
  @@map("cash_transaction")
}

