  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "EmployeeDocument_businessId_fkey")
  employee employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "EmployeeDocument_employeeId_fkey")

  @@index([businessId], map: "EmployeeDocument_businessId_idx")
  @@index([employeeId], map: "EmployeeDocument_employeeId_idx")
  @@map("employee_document")
}

model employee_evaluation {
