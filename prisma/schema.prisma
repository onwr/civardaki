  dayOfWeek   reservation_weekday
  startTime   String
  endTime     String
  isEnabled   Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  settings business_reservation_settings @relation(fields: [settingsId], references: [id], onDelete: Cascade, map: "BusinessReservationAvailability_settingsId_fkey")

  @@index([settingsId], map: "BusinessReservationAvailability_settingsId_idx")
  @@index([settingsId, dayOfWeek], map: "BusinessReservationAvailability_settingsId_dayOfWeek_idx")
  @@map("business_reservation_availability")
}

model business_reservation_question {
  id         String                    @id @default(cuid())
  settingsId String
  label      String
  type       reservation_question_type
  isRequired Boolean                   @default(false)
  isActive   Boolean                   @default(true)
  sortOrder  Int                       @default(0)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  settings business_reservation_settings        @relation(fields: [settingsId], references: [id], onDelete: Cascade, map: "BusinessReservationQuestion_settingsId_fkey")
  options  business_reservation_question_option[]
  answers  reservation_answer[]

  @@index([settingsId], map: "BusinessReservationQuestion_settingsId_idx")
  @@index([settingsId, sortOrder], map: "BusinessReservationQuestion_settingsId_sortOrder_idx")
  @@map("business_reservation_question")
}

model business_reservation_question_option {
  id         String   @id @default(cuid())
  questionId String
  label      String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question business_reservation_question @relation(fields: [questionId], references: [id], onDelete: Cascade, map: "BusinessReservationQuestionOption_questionId_fkey")

  @@index([questionId], map: "BusinessReservationQuestionOption_questionId_idx")
  @@index([questionId, sortOrder], map: "BusinessReservationQuestionOption_questionId_sortOrder_idx")
  @@map("business_reservation_question_option")
}

model reservation_answer {
  id           String   @id @default(cuid())
  reservationId String
  questionId    String
  valueText     String? @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reservation reservation                 @relation(fields: [reservationId], references: [id], onDelete: Cascade, map: "ReservationAnswer_reservationId_fkey")
  question    business_reservation_question @relation(fields: [questionId], references: [id], onDelete: Cascade, map: "ReservationAnswer_questionId_fkey")

  @@index([reservationId], map: "ReservationAnswer_reservationId_idx")
  @@index([questionId], map: "ReservationAnswer_questionId_idx")
  @@map("reservation_answer")
}

model orderitem {
  id        String  @id @default(cuid())
  orderId   String
  name      String
  qty       Int     @default(1)
  price     Float   @default(0)
  productId String?
  variantId String?

  order order @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "OrderItem_orderId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@map("orderitem")
}

// ============================================================================
// LEAD & SALES MODELS
// ============================================================================

model lead {
  id                  String      @id @default(cuid())
  businessId          String?
  name                String
  phone               String?
  email               String?
  message             String      @db.Text
  title               String?     @db.VarChar(200)
  category            String?
  categoryId          String?
  productId           String?
  productNameSnapshot String?
  source              lead_source @default(BUSINESS_PAGE)
  status              lead_status @default(NEW)
  adminNote           String?     @db.Text
  replyText           String?     @db.Text
  quotedPrice         Float?
  repliedAt           DateTime?
  dismissedAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Fraud Detection
  ipHash       String? @db.VarChar(64)
  userAgent    String? @db.VarChar(512)
  fingerprint  String? @db.VarChar(128)
  sourcePage   String? @db.VarChar(255)
  isSuspicious Boolean @default(false)
  spamReason   String? @db.VarChar(255)

  // Location
  city          String?
  district      String?
  isDistributed Boolean @default(false)
  latitude      Float?
  longitude     Float?

  business          business?             @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Lead_businessId_fkey")
  categoryRelation  category?             @relation("LeadCategory", fields: [categoryId], references: [id], onDelete: SetNull, map: "Lead_categoryId_fkey")
  product           product?              @relation(fields: [productId], references: [id], onDelete: SetNull, map: "Lead_productId_fkey")
  leadreminder      leadreminder?
  leadBusinessStates lead_business_state[]

  @@index([businessId, createdAt], map: "Lead_businessId_createdAt_idx")
  @@index([businessId, productId], map: "Lead_businessId_productId_idx")
  @@index([businessId, status], map: "Lead_businessId_status_idx")
  @@index([productId], map: "Lead_productId_fkey")
  @@index([isDistributed, categoryId, createdAt], map: "Lead_distributed_category_createdAt_idx")
  @@index([categoryId], map: "Lead_categoryId_idx")
  @@map("lead")
}

model lead_business_state {
  id          String       @id @default(cuid())
  leadId      String
  businessId  String
  status      lead_status  @default(NEW)
  dismissedAt DateTime?
  replyText   String?      @db.Text
  quotedPrice Float?
  repliedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lead     lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, map: "LeadBusinessState_leadId_fkey")
  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "LeadBusinessState_businessId_fkey")

  @@unique([leadId, businessId], map: "LeadBusinessState_leadId_businessId_key")
  @@index([businessId, status], map: "LeadBusinessState_businessId_status_idx")
  @@index([businessId, dismissedAt], map: "LeadBusinessState_businessId_dismissedAt_idx")
  @@map("lead_business_state")
}

model leadreminder {
  id              String    @id @default(cuid())
  leadId          String    @unique(map: "LeadReminder_leadId_key")
  businessId      String
  scheduledAt     DateTime
  sentAt          DateTime?
  attempts        Int       @default(0)
  lastError       String?   @db.Text
  processingClaim String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "LeadReminder_businessId_fkey")
  lead     lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, map: "LeadReminder_leadId_fkey")

  @@index([businessId], map: "LeadReminder_businessId_fkey")
  @@index([scheduledAt, sentAt], map: "LeadReminder_scheduledAt_sentAt_idx")
  @@map("leadreminder")
}

// ============================================================================
// REVIEW & RATING MODELS
// ============================================================================

model review {
  id           String        @id @default(cuid())
  rating       Int           @default(0)
  content      String?       @db.Text
  replyContent String?       @db.Text
  repliedAt    DateTime?
  metrics      String?       @db.LongText
  likes        Int           @default(0)
  status       review_status @default(PENDING)
