// ============================================================================
// HR & EMPLOYEE MODELS
// ============================================================================

model employee {
  id          String          @id @default(cuid())
  businessId  String
  name        String
  position    String
  email       String?
  phone       String?
  salary      Float           @default(0)
  startDate   DateTime        @default(now())
  status      employee_status @default(ACTIVE)
  performance Int             @default(100)
  leaves      Int             @default(0)
  department  String?
  departmentId String?
  avatar      String?
  tcNo        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Employee_businessId_fkey")
  departmentRef employee_department? @relation(fields: [departmentId], references: [id], onDelete: SetNull, map: "Employee_departmentId_fkey")
  leaveRequests employee_leave_request[]

  @@index([businessId], map: "Employee_businessId_idx")
  @@index([departmentId], map: "Employee_departmentId_idx")
  @@map("employee")
}

model employee_department {
  id         String   @id @default(cuid())
  businessId String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business business  @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "EmployeeDepartment_businessId_fkey")
