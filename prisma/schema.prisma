  businessId String

  user     user?    @relation(fields: [userId], references: [id], onDelete: SetNull, map: "Review_userId_fkey")
  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Review_businessId_fkey")

  @@index([businessId, isApproved], map: "Review_businessId_isApproved_idx")
  @@index([userId], map: "Review_userId_fkey")
  @@map("review")
}

