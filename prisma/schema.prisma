generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH MODELS
// ============================================================================

model user {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique(map: "User_email_key")
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          user_role   @default(USER)
  status        user_status @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  account               account[]
  emaillog              emaillog[]
  ownedbusiness         ownedbusiness[]
  review                review[]
  session               session[]
  financial_transaction financial_transaction[]

  neighborhoodPosts    neighborhood_post[]
  neighborhoodComments neighborhood_post_comment[]
  neighborhoodLikes    neighborhood_post_like[]

  order                  order[]
  reservation            reservation[]
  user_address           user_address[]
  user_favorite_business user_favorite_business[]
  user_profile_settings  user_profile_settings?
  businessadminnote      businessadminnote[]
  businessNotes          business_note[]        @relation("BusinessNoteAuthor")
  requestedLeaveRequests employee_leave_request[] @relation("EmployeeLeaveRequestedBy")
  approvedLeaveRequests  employee_leave_request[] @relation("EmployeeLeaveApprovedBy")
  useradminnote          useradminnote[]         @relation("UserAdminNoteSubject")
  authoredUseradminnote  useradminnote[]         @relation("UserAdminNoteAuthor")
  createdAds             ad[]                   @relation("AdCreatedBy")
  createdBroadcasts      broadcast[]            @relation("BroadcastCreatedBy")
  supportTickets           support_ticket[]           @relation("SupportTicketUser")
  supportTicketMessages   support_ticket_message[]   @relation("SupportTicketMessageUser")

  @@map("user")
}

model user_address {
  id        String   @id @default(cuid())
  userId    String
  title     String
  line1     String   @db.Text
  line2     String?  @db.Text
  city      String
  district  String?
  mahalle   String?
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserAddress_userId_fkey")

  @@index([userId], map: "UserAddress_userId_idx")
  @@map("user_address")
}

model user_favorite_business {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user     user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserFavoriteBusiness_userId_fkey")
  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "UserFavoriteBusiness_businessId_fkey")

  @@unique([userId, businessId], map: "UserFavoriteBusiness_userId_businessId_key")
  @@index([userId], map: "UserFavoriteBusiness_userId_idx")
  @@index([businessId], map: "UserFavoriteBusiness_businessId_idx")
  @@map("user_favorite_business")
}

model user_profile_settings {
  id                     String   @id @default(cuid())
  userId                 String   @unique(map: "UserProfileSettings_userId_key")
  language               String   @default("tr-TR")
  campaignNotifications  Boolean  @default(true)
  smsOrderNotifications  Boolean  @default(true)
  newsletterNotifications Boolean @default(true)
  profileVisibility      String   @default("PRIVATE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserProfileSettings_userId_fkey")

  @@index([userId], map: "UserProfileSettings_userId_idx")
  @@map("user_profile_settings")
}

model account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user user @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@unique([provider, providerAccountId], map: "Account_provider_providerAccountId_key")
  @@index([userId], map: "Account_userId_fkey")
  @@map("account")
}

model session {
  id           String   @id @default(cuid())
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime

  user user @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Session_userId_fkey")

  @@index([userId], map: "Session_userId_fkey")
  @@map("session")
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token], map: "VerificationToken_identifier_token_key")
  @@map("verificationtoken")
}

// ============================================================================
// BUSINESS MODELS
// ============================================================================

model business {
  id          String        @id @default(cuid())
  slug        String        @unique(map: "Business_slug_key")
  name        String
  description String?       @db.Text
  type        business_type @default(INDIVIDUAL)
  category    String?
  phone       String?
  email       String?
  website     String?
  address     String?       @db.Text
  city        String?
  district    String?
  latitude    Float?
  longitude   Float?
  isVerified  Boolean       @default(false)
  isActive    Boolean       @default(true)
  isOpen      Boolean       @default(true)
  reservationEnabled Boolean @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  primaryCategoryId String?

  services           String? @db.LongText
  workingHours       String? @db.LongText
  rating             Float   @default(0)
  ratingSum          Int     @default(0)
  reviewCount        Int     @default(0)
  avgResponseMinutes Float   @default(0)
  responseCount      Int     @default(0)
  referralCode       String? @unique(map: "Business_referralCode_key")

  officialName       String?
  taxId              String?
  taxOffice          String?
  representativeName String?
  vision             String? @db.Text

  cargoSettings        String? @db.LongText
  securitySettings     String? @db.LongText
  notificationSettings String? @db.LongText

  primaryCategory       category?                   @relation("BusinessPrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: SetNull)
  businesscategory      businesscategory[]
  businessevent         businessevent[]
  businesssubscription  businesssubscription?
  subscription_payment  subscription_payment[]
  invoice               invoice[]
  emaillog              emaillog[]
  lead                  lead[]
  leadreminder          leadreminder[]
  media                 media[]
  notification          notification[]
  ownedbusiness         ownedbusiness[]
  product               product[]
  ecommerceProductMatch ecommerce_product_match[]
  productcategory       productcategory[]
  productvariantdimension productvariantdimension[]
  catalog               catalog[]
  pricelist             pricelist[]
  production_run        production_run[]
  warehouse             warehouse[]
  warehouseProductStock warehouse_product_stock[]
  referral              referral[]
  review                review[]
  order                 order[]
  quotes                quote[]
  reservations          reservation[]
  reservationSettings   business_reservation_settings?
  asset                 asset[]
  employee              employee[]
  employeeDepartments   employee_department[]
  employeeLeaveRequests employee_leave_request[]
  employeeDocuments     employee_document[]
  employeeEvaluations   employee_evaluation[]
  calendar_event        calendar_event[]
  cash_account          cash_account[]
  cash_account_document cash_account_document[]
  cash_transaction      cash_transaction[]
  financial_transaction financial_transaction[]
  neighborhoodPosts     neighborhood_post[]
  neighborhoodComments  neighborhood_post_comment[]
  neighborhoodLikes     neighborhood_post_like[]
  user_favorite_business user_favorite_business[]
  businessadminnote     businessadminnote[]
  businessNotes         business_note[]
  supportTickets          support_ticket[]           @relation("SupportTicketBusiness")
  supportTicketMessages   support_ticket_message[]   @relation("SupportTicketMessageBusiness")
  planningProjects        planning_project[]
  planningTasks           planning_task[]
  businessCustomers       business_customer[]
  customerDocuments       customer_document[]
  businessSuppliers       business_supplier[]
  supplierCategories      supplier_category[]
  supplierDocuments       supplier_document[]
  businessSales           business_sale[]
  businessPurchases       business_purchase[]
  expenseCategories       expense_category[]
  expenseItems            expense_item[]
  businessLoans           business_loan[]
  cashProjects            cash_project[]
  cashChecks              cash_check[]
  cashPromissoryNotes     cash_promissory_note[]
  masterdataEntries       business_masterdata_entry[]
  businessFihristEntries  business_fihrist_entry[]
  proposalTemplates       business_proposal_template[]
  labelTemplates          business_label_template[]
  leadBusinessState       lead_business_state[]

  @@index([city, district], map: "Business_city_district_idx")
  @@index([slug], map: "Business_slug_idx")
  @@index([primaryCategoryId], map: "Business_primaryCategoryId_idx")
  @@map("business")
}

model ownedbusiness {
  userId     String
  businessId String
  isPrimary  Boolean @default(false)

  user     user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "OwnedBusiness_userId_fkey")
  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "OwnedBusiness_businessId_fkey")

  @@id([userId, businessId])
  @@index([businessId], map: "OwnedBusiness_businessId_idx")
  @@map("ownedbusiness")
}

model businesscategory {
  businessId String
  categoryId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessCategory_businessId_fkey")
  category category @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "BusinessCategory_categoryId_fkey")

  @@id([businessId, categoryId])
  @@index([categoryId], map: "BusinessCategory_categoryId_fkey")
  @@index([businessId, isPrimary], map: "BusinessCategory_businessId_isPrimary_idx")
  @@index([categoryId, isPrimary], map: "BusinessCategory_categoryId_isPrimary_idx")
  @@map("businesscategory")
}

model businessevent {
  id         String             @id @default(cuid())
  businessId String
  type       businessevent_type
  productId  String?
  createdAt  DateTime           @default(now())
  ipHash     String?            @db.VarChar(64)
  userAgent  String?            @db.VarChar(255)

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessEvent_businessId_fkey")

  @@index([businessId, type, createdAt], map: "BusinessEvent_businessId_type_createdAt_idx")
  @@index([ipHash, createdAt], map: "BusinessEvent_ipHash_createdAt_idx")
  @@map("businessevent")
}

model businesssubscription {
  id         String                      @id @default(cuid())
  businessId String                      @unique(map: "BusinessSubscription_businessId_key")
  status     businesssubscription_status
  plan       businesssubscription_plan   @default(BASIC)
  startedAt  DateTime
  expiresAt  DateTime
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  business  business             @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessSubscription_businessId_fkey")
  subscription_payment subscription_payment[]

  @@index([businessId], map: "BusinessSubscription_businessId_idx")
  @@map("businesssubscription")
}

model subscription_payment {
  id                 String                     @id @default(cuid())
  businessId         String
  subscriptionId     String?
  amount             Float
  currency           String                     @default("TRY")
  status             subscription_payment_status @default(PENDING)
  provider           String?
  providerReference  String?
  paidAt             DateTime?
  metadata           Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  business     business              @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "SubscriptionPayment_businessId_fkey")
  subscription businesssubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull, map: "SubscriptionPayment_subscriptionId_fkey")
  invoice      invoice[]

  @@index([businessId], map: "SubscriptionPayment_businessId_idx")
  @@index([subscriptionId], map: "SubscriptionPayment_subscriptionId_idx")
  @@index([status], map: "SubscriptionPayment_status_idx")
  @@index([providerReference], map: "SubscriptionPayment_providerReference_idx")
  @@index([createdAt], map: "SubscriptionPayment_createdAt_idx")
  @@map("subscription_payment")
}

model invoice {
  id                    String         @id @default(cuid())
  businessId            String
  subscriptionPaymentId String?
  invoiceNumber         String         @unique(map: "Invoice_invoiceNumber_key")
  type                  invoice_type   @default(MANUAL)
  status                invoice_status @default(DRAFT)
  amount                Float
  currency              String         @default("TRY")
  issueDate             DateTime
  dueDate               DateTime
  description           String?        @db.Text
  pdfUrl                String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  business             business              @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Invoice_businessId_fkey")
  subscriptionPayment  subscription_payment? @relation(fields: [subscriptionPaymentId], references: [id], onDelete: SetNull, map: "Invoice_subscriptionPaymentId_fkey")

  @@index([businessId], map: "Invoice_businessId_idx")
  @@index([subscriptionPaymentId], map: "Invoice_subscriptionPaymentId_idx")
  @@index([status], map: "Invoice_status_idx")
  @@index([issueDate], map: "Invoice_issueDate_idx")
  @@map("invoice")
}

model businessadminnote {
  id         String   @id @default(cuid())
  businessId String
  authorId   String?
  note       String   @db.Text
  createdAt  DateTime @default(now())

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessAdminNote_businessId_fkey")
  author   user?    @relation(fields: [authorId], references: [id], onDelete: SetNull, map: "BusinessAdminNote_authorId_fkey")

  @@index([businessId], map: "BusinessAdminNote_businessId_idx")
  @@map("business_admin_note")
}

model useradminnote {
  id        String   @id @default(cuid())
  userId    String
  authorId  String?
  note      String   @db.Text
  createdAt DateTime @default(now())

  user   user  @relation("UserAdminNoteSubject", fields: [userId], references: [id], onDelete: Cascade, map: "UserAdminNote_userId_fkey")
  author user? @relation("UserAdminNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull, map: "UserAdminNote_authorId_fkey")

  @@index([userId], map: "UserAdminNote_userId_idx")
  @@map("user_admin_note")
}

model business_note {
  id           String    @id @default(cuid())
  businessId   String
  authorUserId String?
  title        String
  content      String    @db.Text
  category     String    @default("Genel")
  color        String    @default("blue")
  tags         Json?
  isPinned     Boolean   @default(false)
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessNote_businessId_fkey")
  author   user?    @relation("BusinessNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull, map: "BusinessNote_authorUserId_fkey")

  @@index([businessId, createdAt], map: "BusinessNote_businessId_createdAt_idx")
  @@index([businessId, category], map: "BusinessNote_businessId_category_idx")
  @@index([businessId, isPinned], map: "BusinessNote_businessId_isPinned_idx")
  @@index([businessId, archivedAt], map: "BusinessNote_businessId_archivedAt_idx")
  @@map("business_note")
}

enum business_masterdata_kind {
  PRODUCT_BRAND
  CUSTOMER_CLASS_1
  CUSTOMER_CLASS_2
  SUPPLIER_CLASS_1
  SUPPLIER_CLASS_2
  FIHRIST_1
  FIHRIST_2
  SHELF_LOCATION
}

model business_masterdata_entry {
  id         String                 @id @default(cuid())
  businessId String
  kind       business_masterdata_kind
  name       String
  order      Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessMasterdataEntry_businessId_fkey")
  fihristEntriesClass1 business_fihrist_entry[] @relation("FihristEntryClass1")
  fihristEntriesClass2 business_fihrist_entry[] @relation("FihristEntryClass2")

  @@unique([businessId, kind, name], map: "BusinessMasterdataEntry_businessId_kind_name_key")
  @@index([businessId, kind], map: "BusinessMasterdataEntry_businessId_kind_idx")
  @@map("business_masterdata_entry")
}

/// Fihrist: müşteri/tedarikçi dışı rehber kartları
model business_fihrist_entry {
  id               String   @id @default(cuid())
  businessId       String
  name             String
  phone1           String?
  phone2           String?
  email            String?  @db.Text
  authorizedPerson String?
  address          String?  @db.Text
  note             String?  @db.Text
  imageUrl         String?
  class1Id         String?
  class2Id         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessFihristEntry_businessId_fkey")
  class1   business_masterdata_entry? @relation("FihristEntryClass1", fields: [class1Id], references: [id], onDelete: SetNull, map: "BusinessFihristEntry_class1Id_fkey")
  class2   business_masterdata_entry? @relation("FihristEntryClass2", fields: [class2Id], references: [id], onDelete: SetNull, map: "BusinessFihristEntry_class2Id_fkey")

  @@index([businessId], map: "BusinessFihristEntry_businessId_idx")
  @@index([class1Id], map: "BusinessFihristEntry_class1Id_idx")
  @@index([class2Id], map: "BusinessFihristEntry_class2Id_idx")
  @@map("business_fihrist_entry")
}

enum proposal_template_kind {
  PURCHASE_NOTE
  BA_BS_FORM
  SALES_NOTE
  QUOTE
  CUSTOM
}

model business_proposal_template {
  id              String                 @id @default(cuid())
  businessId      String
  name            String
  kind            proposal_template_kind
  language        String                 @default("tr")
  documentTitle   String                 @default("TEKLİF FORMU")
  pageSize        String                 @default("A4")
  introText       String?                @db.Text
  footerText      String?                @db.Text
  layoutSettings  Json                   @default("{}")
  order           Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessProposalTemplate_businessId_fkey")

  @@unique([businessId, name], map: "BusinessProposalTemplate_businessId_name_key")
  @@index([businessId], map: "BusinessProposalTemplate_businessId_idx")
  @@map("business_proposal_template")
}

enum label_template_category {
  PRODUCT
  ADDRESS
}

enum label_sheet_format {
  A4
  RIBBON
}

model business_label_template {
  id         String                 @id @default(cuid())
  businessId String
  name       String
  category   label_template_category
  format     label_sheet_format
  settings   Json                   @default("{}")
  order      Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessLabelTemplate_businessId_fkey")

  @@unique([businessId, name], map: "BusinessLabelTemplate_businessId_name_key")
  @@index([businessId], map: "BusinessLabelTemplate_businessId_idx")
  @@map("business_label_template")
}

/// Cari müşteri (BizimHesap tarzı; panel içi, Civardaki dışı)
model business_customer {
  id        String   @id @default(cuid())
  businessId String
  name      String
  isActive  Boolean  @default(true)
  customerClass String @default("GENEL")
  openBalance        Decimal @default(0) @db.Decimal(14, 2)
  checkNoteBalance   Decimal @default(0) @db.Decimal(14, 2)
  integrationLabel   String?
  imageUrl           String?

  email              String?  @db.Text
  mobilePhone        String?
  phone2             String?
  otherAccess        String?  @db.Text
  authorizedPerson   String?
  address            String?  @db.Text
  shippingAddresses  Json?

  taxOffice          String?
  taxId              String?
  taxExempt          Boolean  @default(false)
  bankInfo           String?  @db.Text
  currency           String   @default("TRY")
  riskLimit          Decimal  @default(0) @db.Decimal(14, 2)
  maturityDays       Int?
  fixedDiscountPct   Decimal? @db.Decimal(5, 2)
  priceListMode      String?
  openingBalance     Decimal  @default(0) @db.Decimal(14, 2)

  otherNotes         String?  @db.Text
  branchesJson       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business     business       @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessCustomer_businessId_fkey")
  documents    customer_document[]
  business_sales business_sale[]

  @@index([businessId], map: "BusinessCustomer_businessId_idx")
  @@index([businessId, isActive], map: "BusinessCustomer_businessId_isActive_idx")
  @@map("business_customer")
}

model customer_document {
  id         String   @id @default(cuid())
  businessId String
  customerId String
  title      String
  url        String
  fileId     String?
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business business          @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "CustomerDocument_businessId_fkey")
  customer business_customer @relation(fields: [customerId], references: [id], onDelete: Cascade, map: "CustomerDocument_customerId_fkey")

  @@index([businessId], map: "CustomerDocument_businessId_idx")
  @@index([customerId], map: "CustomerDocument_customerId_idx")
  @@index([createdAt], map: "CustomerDocument_createdAt_idx")
  @@map("customer_document")
}

/// Tedarikçi (BizimHesap tarzı; panel içi)
model business_supplier {
  id          String   @id @default(cuid())
  businessId  String
  categoryId  String?
  name        String
  isActive    Boolean  @default(true)
  imageUrl    String?

  taxOffice      String?
  taxId          String?
  taxExempt      Boolean  @default(false)
  bankInfo       String?  @db.Text
  currency       String   @default("TRY")
  maturityDays   Int?
  openingBalance Decimal @default(0) @db.Decimal(14, 2)

  authorizedPerson String?
  email           String?  @db.Text
  address         String?  @db.Text
  phone           String?
  otherAccess     String?  @db.Text

  otherNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business         business         @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessSupplier_businessId_fkey")
  category         supplier_category? @relation(fields: [categoryId], references: [id], onDelete: SetNull, map: "BusinessSupplier_categoryId_fkey")
  documents        supplier_document[]
  business_purchases business_purchase[]

  @@index([businessId], map: "BusinessSupplier_businessId_idx")
  @@index([categoryId], map: "BusinessSupplier_categoryId_idx")
  @@index([businessId, isActive], map: "BusinessSupplier_businessId_isActive_idx")
  @@map("business_supplier")
}

model supplier_category {
  id         String   @id @default(cuid())
  businessId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business  business           @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "SupplierCategory_businessId_fkey")
  suppliers business_supplier[]

  @@unique([businessId, name], map: "SupplierCategory_businessId_name_key")
  @@index([businessId], map: "SupplierCategory_businessId_idx")
  @@map("supplier_category")
}

model supplier_document {
  id         String   @id @default(cuid())
  businessId String
  supplierId String
  title      String
  url        String
  fileId     String?
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business business          @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "SupplierDocument_businessId_fkey")
  supplier business_supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade, map: "SupplierDocument_supplierId_fkey")

  @@index([businessId], map: "SupplierDocument_businessId_idx")
  @@index([supplierId], map: "SupplierDocument_supplierId_idx")
  @@index([createdAt], map: "SupplierDocument_createdAt_idx")
  @@map("supplier_document")
}

/// Panel satış belgesi (BizimHesap Satışlar)
model business_sale {
  id              String              @id @default(cuid())
  businessId      String
  documentType    sale_document_type   @default(ORDER)
  saleKind        sale_kind           @default(RETAIL)
  customerId      String?
  customerName    String?
  saleDate        DateTime
  totalAmount     Float               @default(0)
  collectionAmount Float              @default(0)
  cashAccountId   String?
  projectId       String?
  description     String?             @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  business     business         @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessSale_businessId_fkey")
  customer     business_customer? @relation(fields: [customerId], references: [id], onDelete: SetNull, map: "BusinessSale_customerId_fkey")
  cashAccount  cash_account?    @relation(fields: [cashAccountId], references: [id], onDelete: SetNull, map: "BusinessSale_cashAccountId_fkey")
  project      cash_project?    @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "BusinessSale_projectId_fkey")
  items        business_sale_item[]

  @@index([businessId], map: "BusinessSale_businessId_idx")
  @@index([projectId], map: "BusinessSale_projectId_idx")
  @@index([businessId, saleDate], map: "BusinessSale_businessId_saleDate_idx")
  @@index([documentType], map: "BusinessSale_documentType_idx")
  @@map("business_sale")
}

model business_sale_item {
  id         String   @id @default(cuid())
  saleId     String
  productId  String?
  productVariantId String?
  name       String
  quantity   Float    @default(1)
  unitPrice  Float    @default(0)
  total      Float    @default(0)

  sale business_sale @relation(fields: [saleId], references: [id], onDelete: Cascade, map: "BusinessSaleItem_saleId_fkey")
  productVariant productvariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull, map: "BusinessSaleItem_productVariantId_fkey")

  @@index([saleId], map: "BusinessSaleItem_saleId_idx")
  @@index([productVariantId], map: "BusinessSaleItem_productVariantId_idx")
  @@map("business_sale_item")
}

/// Panel alış belgesi (BizimHesap Alışlar)
model business_purchase {
  id              String                  @id @default(cuid())
  businessId      String
  documentType    purchase_document_type   @default(ORDER)
  supplierId      String?
  supplierName    String?
  purchaseDate    DateTime
  totalAmount     Float                   @default(0)
  paymentAmount   Float                   @default(0)
  cashAccountId   String?
  projectId       String?
  description     String?                 @db.Text
  isCancelled     Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  business     business         @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "BusinessPurchase_businessId_fkey")
  supplier     business_supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull, map: "BusinessPurchase_supplierId_fkey")
  cashAccount  cash_account?    @relation(fields: [cashAccountId], references: [id], onDelete: SetNull, map: "BusinessPurchase_cashAccountId_fkey")
  project      cash_project?    @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "BusinessPurchase_projectId_fkey")
  items        business_purchase_item[]

  @@index([businessId], map: "BusinessPurchase_businessId_idx")
  @@index([projectId], map: "BusinessPurchase_projectId_idx")
  @@index([businessId, purchaseDate], map: "BusinessPurchase_businessId_purchaseDate_idx")
  @@index([documentType], map: "BusinessPurchase_documentType_idx")
  @@map("business_purchase")
}

model business_purchase_item {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String?
  name       String
  quantity   Float    @default(1)
  unitPrice  Float    @default(0)
  total      Float    @default(0)

  purchase business_purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade, map: "BusinessPurchaseItem_purchaseId_fkey")

  @@index([purchaseId], map: "BusinessPurchaseItem_purchaseId_idx")
  @@map("business_purchase_item")
}

// ============================================================================
// ADS (Reklamlar)
// ============================================================================

model ad {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  imageUrl    String?
  linkUrl     String?
  placement   ad_placement
  status      ad_status     @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  sortOrder   Int           @default(0)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy user? @relation("AdCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, map: "Ad_createdById_fkey")

  @@index([placement, status], map: "Ad_placement_status_idx")
  @@index([status, startAt, endAt], map: "Ad_status_dates_idx")
  @@map("ad")
}

// ============================================================================
// BROADCASTS (Duyurular)
// ============================================================================

model broadcast {
  id          String              @id @default(cuid())
  title       String
  body        String?             @db.Text
  imageUrl    String?
  linkUrl     String?
  linkLabel   String?
  layout      broadcast_layout
  audience    broadcast_audience
  status      broadcast_status    @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  sortOrder   Int                 @default(0)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  createdBy user? @relation("BroadcastCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, map: "Broadcast_createdById_fkey")

  @@index([layout, audience, status], map: "Broadcast_layout_audience_status_idx")
  @@index([status, startAt, endAt], map: "Broadcast_status_dates_idx")
  @@map("broadcast")
}

// ============================================================================
// SUPPORT TICKETS (Destek Talepleri)
// ============================================================================

model support_ticket {
  id          String               @id @default(cuid())
  subject     String
  body        String                @db.Text
  creatorType ticket_creator_type
  userId      String?
  businessId  String?
  status      ticket_status         @default(OPEN)
  priority    ticket_priority       @default(MEDIUM)
  category    ticket_category       @default(GENERAL)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user     user?                    @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: SetNull, map: "SupportTicket_userId_fkey")
  business business?                @relation("SupportTicketBusiness", fields: [businessId], references: [id], onDelete: SetNull, map: "SupportTicket_businessId_fkey")
  messages support_ticket_message[]

  @@index([status, createdAt], map: "SupportTicket_status_createdAt_idx")
  @@index([userId], map: "SupportTicket_userId_idx")
  @@index([businessId], map: "SupportTicket_businessId_idx")
  @@map("support_ticket")
}

model support_ticket_message {
  id               String                     @id @default(cuid())
  supportTicketId  String
  body             String                     @db.Text
  authorType       ticket_message_author_type
  authorUserId     String?
  authorBusinessId String?
  createdAt        DateTime                   @default(now())

  supportTicket support_ticket @relation(fields: [supportTicketId], references: [id], onDelete: Cascade, map: "SupportTicketMessage_supportTicketId_fkey")
  user          user?          @relation("SupportTicketMessageUser", fields: [authorUserId], references: [id], onDelete: SetNull, map: "SupportTicketMessage_authorUserId_fkey")
  business      business?     @relation("SupportTicketMessageBusiness", fields: [authorBusinessId], references: [id], onDelete: SetNull, map: "SupportTicketMessage_authorBusinessId_fkey")

  @@index([supportTicketId], map: "SupportTicketMessage_supportTicketId_idx")
  @@map("support_ticket_message")
}

// ============================================================================
// CATEGORY MODELS
// ============================================================================

model category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique(map: "Category_slug_key")
  description String?  @db.Text
  icon        String?
  color       String?
  imageUrl    String?
  parentId    String?
  level       Int      @default(0)
  path        String?  @db.VarChar(500)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  keywords    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent            category?          @relation("category_children", fields: [parentId], references: [id], onDelete: Cascade, map: "Category_parentId_fkey")
  children          category[]         @relation("category_children")
  businesscategory  businesscategory[]
  primaryBusinesses business[]         @relation("BusinessPrimaryCategory")
  leads             lead[]             @relation("LeadCategory")

  @@unique([parentId, name], map: "Category_parentId_name_key")
  @@index([parentId, sortOrder], map: "Category_parentId_sortOrder_idx")
  @@index([level, isActive], map: "Category_level_isActive_idx")
  @@index([isActive, isFeatured], map: "Category_isActive_isFeatured_idx")
  @@map("category")
}

// ============================================================================
// PRODUCT & INVENTORY MODELS
// ============================================================================

model product {
  id            String   @id @default(cuid())
  businessId    String
  categoryId    String?
  name          String
  slug          String
  brand         String?
  description   String?  @db.Text
  price         Float?
  discountPrice Float?
  /// TL | USD | EUR (boş = TL)
  priceCurrency String?  @db.VarChar(8)
  /// Satış birimi kodu (örn. ADET, KG)
  salesUnit     String?  @db.VarChar(32)
  /// Etiketler, satır veya virgülle ayrılmış
  tagsString    String?  @db.Text
  imageUrl      String?
  /// Resim 2–6: https URL'leri (JSON dizi, en fazla 5 öğe)
  imageGallery  Json?
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  stock         Int?     // Stok (varyasyon yoksa ürün bazlı)
  maxOrderQty   Int?     // Maksimum sipariş adedi (null = sınırsız)
  /// EAN-13 veya serbest barkod metni
  barcode       String?  @db.VarChar(32)
  /// İç ürün kodu / SKU
  productCode   String?  @db.VarChar(64)
  gtip          String?  @db.VarChar(32)
  gtin          String?  @db.VarChar(32)
  /// Harici ülke listesi id (örn. "12" = Türkiye)
  countryCode   String?  @db.VarChar(8)
  shelfLocation String?  @db.VarChar(128)
  /// NORMAL | NONE | BATCH | SERIAL
  stockTracking String   @default("NORMAL") @db.VarChar(16)
  /// Seri takipte satış faturasında seri gösterimi: HIDE | SHOW | OPTIONAL
  serialInvoiceMode String? @db.VarChar(16)
  /// Civardaki pazaryerinde listelensin
  publishedOnMarketplace Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business        business         @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Product_businessId_fkey")
  productcategory productcategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "Product_categoryId_fkey")
  productvariant  productvariant[]
  catalogitem     catalogitem[]
  pricelistitem   pricelistitem[]
  production_run  production_run[]
  production_run_line production_run_line[]
  lead            lead[]
  ecommerceMatches ecommerce_product_match[]
  warehouseProductStocks warehouse_product_stock[]

  @@unique([businessId, slug], map: "Product_businessId_slug_key")
  @@index([businessId], map: "Product_businessId_idx")
  @@index([businessId, brand], map: "Product_businessId_brand_idx")
  @@index([categoryId], map: "Product_categoryId_fkey")
  @@map("product")
}

model ecommerce_product_match {
  id                  String                @id @default(cuid())
  businessId          String
  productId           String
  platform            String
  platformProductId   String?
  platformProductName String?
  matchStatus         ecommerce_match_status @default(NOT_LISTED)
  lastSyncedAt        DateTime?
  notes               String?               @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "EcommerceProductMatch_businessId_fkey")
  product  product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "EcommerceProductMatch_productId_fkey")

  @@unique([businessId, productId, platform], map: "EcommerceProductMatch_businessId_productId_platform_key")
  @@index([businessId, platform], map: "EcommerceProductMatch_businessId_platform_idx")
  @@index([businessId, matchStatus], map: "EcommerceProductMatch_businessId_matchStatus_idx")
  @@index([productId], map: "EcommerceProductMatch_productId_idx")
  @@map("ecommerce_product_match")
}

model productvariant {
  id            String   @id @default(cuid())
  productId     String
  name          String   // Örn: Büyük Boy, Kırmızı
  sku           String?
  price         Float?   // Varyasyon fiyatı (boşsa ürün fiyatı)
  discountPrice Float?
  stock         Int      @default(0)
  maxOrderQty   Int?     // Maksimum sipariş adedi (null = sınırsız)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product product @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ProductVariant_productId_fkey")
  production_run_line production_run_line[]
  business_sale_item business_sale_item[]

  @@index([productId], map: "ProductVariant_productId_idx")
  @@map("productvariant")
}

/// İşletme geneli varyant boyutu (örn. RENK, BOYUT/EBAT)
model productvariantdimension {
  id         String   @id @default(cuid())
  businessId String
  name       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business business                        @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "ProductVariantDimension_businessId_fkey")
  values   productvariantdimensionvalue[]

  @@index([businessId], map: "ProductVariantDimension_businessId_idx")
  @@map("productvariantdimension")
}

model productvariantdimensionvalue {
  id          String @id @default(cuid())
  dimensionId String
  value       String
  order       Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dimension productvariantdimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade, map: "ProductVariantDimensionValue_dimensionId_fkey")

  @@unique([dimensionId, value], map: "ProductVariantDimensionValue_dimensionId_value_key")
  @@index([dimensionId], map: "ProductVariantDimensionValue_dimensionId_idx")
  @@map("productvariantdimensionvalue")
}

model productcategory {
  id         String @id @default(cuid())
  businessId String
  name       String
  order      Int    @default(0)

  business business  @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "ProductCategory_businessId_fkey")
  product  product[]

  @@unique([businessId, name], map: "ProductCategory_businessId_name_key")
  @@map("productcategory")
}

enum catalog_price_display {
  SHOW_SALES
  HIDE
}

enum catalog_brand_display {
  SHOW
  HIDE
}

enum catalog_stock_qty_display {
  SHOW
  HIDE
}

enum catalog_stock_filter {
  ALL
  IN_STOCK_ONLY
}

enum catalog_sort {
  BY_NAME
  BY_CATALOG_ORDER
  BY_SLUG
  BY_CATEGORY
  PRICE_ASC
  PRICE_DESC
}

model catalog {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?  @db.Text
  isPublished Boolean @default(false)
  pdfUrl      String?
  shareUrl    String?
  shareSlug   String?  @unique(map: "Catalog_shareSlug_key")
  priceListId String?
  priceDisplay   catalog_price_display   @default(SHOW_SALES)
  brandDisplay   catalog_brand_display   @default(HIDE)
  stockQtyDisplay catalog_stock_qty_display @default(HIDE)
  stockFilter    catalog_stock_filter    @default(ALL)
  sortOrder      catalog_sort            @default(BY_NAME)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business  business   @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Catalog_businessId_fkey")
  priceList pricelist? @relation(fields: [priceListId], references: [id], onDelete: SetNull, map: "Catalog_priceListId_fkey")
  items     catalogitem[]

  @@index([businessId], map: "Catalog_businessId_idx")
  @@index([priceListId], map: "Catalog_priceListId_idx")
  @@map("catalog")
}

model catalogitem {
  id        String  @id @default(cuid())
  catalogId String
  productId String
  order     Int     @default(0)

  catalog catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade, map: "CatalogItem_catalogId_fkey")
  product product @relation(fields: [productId], references: [id], onDelete: Cascade, map: "CatalogItem_productId_fkey")

  @@unique([catalogId, productId], map: "CatalogItem_catalogId_productId_key")
  @@index([catalogId], map: "CatalogItem_catalogId_idx")
  @@index([productId], map: "CatalogItem_productId_idx")
  @@map("catalogitem")
}

model pricelist {
  id           String    @id @default(cuid())
  businessId   String
  name         String
  description  String?   @db.Text
  customerGroup String   @default("ALL") // ALL, VIP, BULK, NEW, CORPORATE
  discountRate Float    @default(0)
  validFrom    DateTime
  validUntil   DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business business        @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Pricelist_businessId_fkey")
  items    pricelistitem[]
  catalogs catalog[]

  @@index([businessId], map: "Pricelist_businessId_idx")
  @@map("pricelist")
}

model pricelistitem {
  id         String  @id @default(cuid())
  pricelistId String
  productId  String
  order      Int     @default(0)

  pricelist pricelist @relation(fields: [pricelistId], references: [id], onDelete: Cascade, map: "PricelistItem_pricelistId_fkey")
  product   product   @relation(fields: [productId], references: [id], onDelete: Cascade, map: "PricelistItem_productId_fkey")

  @@unique([pricelistId, productId], map: "PricelistItem_pricelistId_productId_key")
  @@index([pricelistId], map: "PricelistItem_pricelistId_idx")
  @@index([productId], map: "PricelistItem_productId_idx")
  @@map("pricelistitem")
}

model production_run {
  id        String   @id @default(cuid())
  businessId String
  productId  String
  outputWarehouseId String?
  quantity   Float   @default(0)
  unit       String  @default("kg") // kg, adet, litre, vb.
  recipe     String? @db.Text
  description String? @db.Text
  startDate  DateTime
  endDate    DateTime
  status     String  @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  cost       Float   @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "ProductionRun_businessId_fkey")
  product  product  @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ProductionRun_productId_fkey")
  outputWarehouse warehouse? @relation("ProductionRun_outputWarehouse", fields: [outputWarehouseId], references: [id], onDelete: SetNull, map: "ProductionRun_outputWarehouseId_fkey")
  lines    production_run_line[]

  @@index([businessId], map: "ProductionRun_businessId_idx")
  @@index([productId], map: "ProductionRun_productId_idx")
  @@index([outputWarehouseId], map: "ProductionRun_outputWarehouseId_idx")
  @@map("production_run")
}

model production_run_line {
  id               String   @id @default(cuid())
  productionRunId  String
  productId        String
  warehouseId      String
  productVariantId String?
  quantity         Float    @default(0)
  unitCost         Float    @default(0)
  lineCost         Float    @default(0)
  description      String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productionRun  production_run  @relation(fields: [productionRunId], references: [id], onDelete: Cascade, map: "ProductionRunLine_productionRunId_fkey")
  product        product         @relation(fields: [productId], references: [id], onDelete: Cascade, map: "ProductionRunLine_productId_fkey")
  warehouse      warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade, map: "ProductionRunLine_warehouseId_fkey")
  productVariant productvariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull, map: "ProductionRunLine_productVariantId_fkey")

  @@index([productionRunId], map: "ProductionRunLine_productionRunId_idx")
  @@index([productId], map: "ProductionRunLine_productId_idx")
  @@index([warehouseId], map: "ProductionRunLine_warehouseId_idx")
  @@map("production_run_line")
}

model warehouse {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  address      String?  @db.Text
  capacity     Int?     // toplam kapasite (birim serbest)
  currentStock Int      @default(0)
  manager      String?
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business               business                 @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Warehouse_businessId_fkey")
  warehouseProductStocks warehouse_product_stock[]
  productionRunsAsOutput production_run[]         @relation("ProductionRun_outputWarehouse")
  production_run_lines   production_run_line[]

  @@index([businessId], map: "Warehouse_businessId_idx")
  @@map("warehouse")
}

/// Depo bazlı ürün miktarı (negatif olabilir)
model warehouse_product_stock {
  id          String   @id @default(cuid())
  businessId  String
  warehouseId String
  productId   String
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business  business  @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "WarehouseProductStock_businessId_fkey")
  warehouse warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade, map: "WarehouseProductStock_warehouseId_fkey")
  product   product   @relation(fields: [productId], references: [id], onDelete: Cascade, map: "WarehouseProductStock_productId_fkey")

  @@unique([warehouseId, productId], map: "WarehouseProductStock_warehouseId_productId_key")
  @@index([businessId], map: "WarehouseProductStock_businessId_idx")
  @@index([warehouseId], map: "WarehouseProductStock_warehouseId_idx")
  @@index([productId], map: "WarehouseProductStock_productId_idx")
  @@map("warehouse_product_stock")
}

// ============================================================================
// ORDER MODELS
// ============================================================================

model order {
  id             String       @id @default(cuid())
  businessId     String
  userId         String?
  orderNumber    String       @unique(map: "Order_orderNumber_key")
  customerName   String
  customerAvatar String?
  customerLoc    String?
  customerNote   String?      @db.Text
  type           order_type   @default(PRODUCT)
  status         order_status @default(PENDING)
  deliveryType   String?
  paymentMethod  String?
  subtotal       Float        @default(0)
  total          Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  business business    @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Order_businessId_fkey")
  user     user?       @relation(fields: [userId], references: [id], onDelete: SetNull, map: "Order_userId_fkey")
  items    orderitem[]

  @@index([businessId, status], map: "Order_businessId_status_idx")
  @@index([businessId, createdAt], map: "Order_businessId_createdAt_idx")
  @@index([userId], map: "Order_userId_idx")
  @@map("order")
}

model reservation {
  id           String             @id @default(cuid())
  businessId   String
  userId       String?
  customerName String
  customerPhone String?
  customerEmail String?
  serviceName  String
  notes        String?            @db.Text
  source       reservation_source @default(PUBLIC_LISTING)
  status       reservation_status @default(PENDING)
  startAt      DateTime
  endAt        DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Reservation_businessId_fkey")
  user     user?    @relation(fields: [userId], references: [id], onDelete: SetNull, map: "Reservation_userId_fkey")
  answers  reservation_answer[]

  @@index([businessId, startAt], map: "Reservation_businessId_startAt_idx")
  @@index([businessId, status], map: "Reservation_businessId_status_idx")
  @@index([userId, startAt], map: "Reservation_userId_startAt_idx")
  @@map("reservation")
}

model quote {
  id                String         @id @default(cuid())
  businessId        String
  quoteNumber       String
  customerName      String
  customerCompany   String?
  customerEmail     String?
  customerPhone     String?
  quoteDate         DateTime
  validUntil        DateTime
  sentDate          DateTime?
  acceptedDate      DateTime?
  followUpDate      DateTime?
  expectedCloseDate DateTime?
  subtotal          Float          @default(0)
  discount          Float          @default(0)
  tax               Float          @default(0)
  total             Float          @default(0)
  exchangeRate      Float?
  status            quote_status   @default(DRAFT)
  priority          quote_priority @default(NORMAL)
  probability       Int            @default(0)
  convertedToSale   Boolean        @default(false)
  template          String?        @default("Standard")
  termsAndConditions String?       @db.Text
  notes             String?        @db.Text
  tags              Json?
  budget            Float?
  timeline          String?
  requirements      String?        @db.Text
  objections        String?        @db.Text
  nextSteps         String?        @db.Text
  competitor        String?
  decisionMaker     String?
  createdBy         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  business business    @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Quote_businessId_fkey")
  items    quote_item[]

  @@unique([businessId, quoteNumber], map: "Quote_businessId_quoteNumber_key")
  @@index([businessId, status], map: "Quote_businessId_status_idx")
  @@index([businessId, createdAt], map: "Quote_businessId_createdAt_idx")
  @@index([businessId, validUntil], map: "Quote_businessId_validUntil_idx")
  @@map("quote")
}

model quote_item {
