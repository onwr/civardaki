  employeeId       String
  leaveType        employee_leave_type
  startDate        DateTime
  endDate          DateTime
  days             Int
  reason           String                @db.Text
  notes            String?               @db.Text
  status           employee_leave_status @default(PENDING)
  requestedByUserId String?
  approvedByUserId  String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  business    business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "EmployeeLeaveRequest_businessId_fkey")
  employee    employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "EmployeeLeaveRequest_employeeId_fkey")
  requestedBy user?    @relation("EmployeeLeaveRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull, map: "EmployeeLeaveRequest_requestedByUserId_fkey")
  approvedBy  user?    @relation("EmployeeLeaveApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull, map: "EmployeeLeaveRequest_approvedByUserId_fkey")

  @@index([businessId, status], map: "EmployeeLeaveRequest_businessId_status_idx")
  @@index([businessId, startDate], map: "EmployeeLeaveRequest_businessId_startDate_idx")
  @@index([employeeId, status], map: "EmployeeLeaveRequest_employeeId_status_idx")
  @@map("employee_leave_request")
}

