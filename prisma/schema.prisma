// ============================================================================
// HR & EMPLOYEE MODELS
// ============================================================================

model employee {
  id          String          @id @default(cuid())
  businessId  String
  name        String
  position    String
  email       String?
  phone       String?
  salary      Float           @default(0)
  startDate   DateTime        @default(now())
  status      employee_status @default(ACTIVE)
  performance Int             @default(100)
  leaves      Int             @default(0)
  department  String?
  departmentId String?
  avatar      String?
  tcNo        String?
  performanceNotes String?  @db.Text
  kpiTargets       String?  @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Employee_businessId_fkey")
