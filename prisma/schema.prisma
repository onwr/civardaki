  business business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "EmployeeEvaluation_businessId_fkey")
  employee employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "EmployeeEvaluation_employeeId_fkey")

  @@index([businessId], map: "EmployeeEvaluation_businessId_idx")
  @@index([employeeId], map: "EmployeeEvaluation_employeeId_idx")
  @@map("employee_evaluation")
}

model employee_department {
