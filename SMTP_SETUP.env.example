# ─── Email (SMTP) Configuration for Lead Notifications ──────────────────────
# lib/mailer.js uses these. If not set, emails are silently skipped.
#
# Option A — Brevo (Sendinblue) Free Tier: 300 emails/day
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=<your-brevo-login-email>
#   SMTP_PASS=<brevo-smtp-key-from-settings>
#
# Option B — Mailgun
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_USER=postmaster@mg.yourdomain.com
#   SMTP_PASS=<mailgun-smtp-password>
#
# Option C — Gmail App Password (dev only, not production-safe)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=<gmail-app-password>

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Civardaki.com <noreply@civardaki.com>"

# ─── App URL (used in email CTAs) ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://civardaki.com
